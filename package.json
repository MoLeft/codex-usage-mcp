{
  "name": "codex-usage-mcp",
  "version": "0.1.0",
  "description": "MCP server for Codex CLI usage summaries from local session logs.",
  "type": "module",
  "bin": {
    "codex-usage-mcp": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json",
    "clean": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "prepublishOnly": "npm run build && npm run test",
    "test": "npm run build && vitest run"
  },
  "keywords": [
    "codex",
    "mcp",
    "model-context-protocol",
    "openai",
    "token-usage"
  ],
  "author": "MoLeft",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MoLeft/codex-usage-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/MoLeft/codex-usage-mcp/issues"
  },
  "homepage": "https://github.com/MoLeft/codex-usage-mcp#readme",
  "engines": {
    "node": ">=18.18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
